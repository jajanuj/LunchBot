{
  "name": "lunchbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e:smoke": "node e2e/smoke.test.mjs",
    "test:e2e:login": "node e2e/login.test.mjs",
    "test:e2e:employees": "node e2e/employees.test.mjs",
    "test:e2e:employees-bulk": "node e2e/employees-bulk-import.test.mjs",
    "test:e2e:menus": "node e2e/menus.test.mjs",
    "test:e2e:line-webhook": "node --env-file=.env.local e2e/line-webhook.test.mjs",
    "test:e2e:line-flex-message": "node --no-warnings e2e/line-flex-message.test.mjs",
    "test:e2e:liff-order": "node e2e/liff-order.test.mjs",
    "test:e2e:cron-menu-maintenance": "node --env-file=.env.local e2e/cron-menu-maintenance.test.mjs",
    "test:e2e:menu-reminder-logic": "node --no-warnings --env-file=.env.local e2e/menu-reminder-logic.test.mjs",
    "test:e2e:assisted-order": "node e2e/assisted-order.test.mjs",
    "test:e2e:ai-menu-import": "node --env-file=.env.local e2e/ai-menu-import.test.mjs",
    "test:e2e:templates": "node e2e/templates.test.mjs",
    "test:e2e:order-summary": "node e2e/order-summary.test.mjs",
    "test:e2e:payroll": "node e2e/payroll.test.mjs",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:login && npm run test:e2e:employees && npm run test:e2e:employees-bulk && npm run test:e2e:menus && npm run test:e2e:line-webhook && npm run test:e2e:line-flex-message && npm run test:e2e:liff-order && npm run test:e2e:cron-menu-maintenance && npm run test:e2e:menu-reminder-logic && npm run test:e2e:assisted-order && npm run test:e2e:ai-menu-import && npm run test:e2e:templates && npm run test:e2e:order-summary && npm run test:e2e:payroll",
    "verify:line-push": "node --env-file=.env.local e2e/manual-verify-line-push.mjs"
  },
  "dependencies": {
    "@line/bot-sdk": "^11.0.1",
    "@line/liff": "^2.29.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
