{
  "name": "lunchbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e:smoke": "node e2e/smoke.test.mjs",
    "test:e2e:login": "node e2e/login.test.mjs",
    "test:e2e:employees": "node e2e/employees.test.mjs",
    "test:e2e:employees-bulk": "node e2e/employees-bulk-import.test.mjs",
    "test:e2e:menus": "node e2e/menus.test.mjs",
    "test:e2e:line-webhook": "node --env-file=.env.local e2e/line-webhook.test.mjs",
    "test:e2e:line-flex-message": "node --no-warnings e2e/line-flex-message.test.mjs",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:login && npm run test:e2e:employees && npm run test:e2e:employees-bulk && npm run test:e2e:menus && npm run test:e2e:line-webhook && npm run test:e2e:line-flex-message",
    "verify:line-push": "node --env-file=.env.local e2e/manual-verify-line-push.mjs"
  },
  "dependencies": {
    "@line/bot-sdk": "^11.0.1",
    "@line/liff": "^2.29.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
