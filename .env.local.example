# 複製這個檔案為 .env.local，並依需要填入實際值。
# .env.local 不會進版控，請勿把正式金鑰寫在這個 .example 檔案裡。

# 用於簽署 session cookie 的密鑰，任意隨機字串即可（可用 `openssl rand -hex 32` 產生）
AUTH_SECRET=

# 開發階段的假帳號（尚未串接 Supabase Auth 前，後台登入用）
MOCK_ADMIN_EMAIL=admin@lunchbot.local
MOCK_ADMIN_PASSWORD=changeme123

# LINE Login channel「LunchBot 點餐」底下的 LIFF App「員工點餐頁」
# LIFF ID 不是敏感資訊（會直接嵌在前端網址/程式碼裡），可以放實際值在這裡
NEXT_PUBLIC_LINE_LIFF_ID=2010418986-djEPOUcf

# StockBot（Messaging API channel）的金鑰，Bot 推播/Webhook 驗證用
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# 測試群組 ID（StockBot 已加入，從 Webhook log 取得）
LINE_GROUP_ID=

# 排程端點驗證密鑰，可用 `openssl rand -hex 24` 產生
# Vercel 上要在 Environment Variables 設定一樣的值
CRON_SECRET=

# Supabase：建立專案後，在 Project Settings > API 取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API Key：至 https://aistudio.google.com/apikey 申請
GEMINI_API_KEY=
