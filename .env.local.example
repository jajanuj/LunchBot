# 複製這個檔案為 .env.local，並依需要填入實際值。
# .env.local 不會進版控，請勿把正式金鑰寫在這個 .example 檔案裡。

# 用於簽署 session cookie 的密鑰，任意隨機字串即可（可用 `openssl rand -hex 32` 產生）
AUTH_SECRET=

# 開發階段的假帳號（尚未串接 Supabase Auth 前，後台登入用）
MOCK_ADMIN_EMAIL=admin@lunchbot.local
MOCK_ADMIN_PASSWORD=changeme123

# --- 以下為日後串接 Supabase / LINE / Gemini 時會用到的環境變數（尚未全部啟用） ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
# LINE_GROUP_ID=
# GEMINI_API_KEY=

# 排程端點（/api/cron/close-expired-menus）驗證密鑰，可用
# `openssl rand -hex 24` 產生，Vercel 上要設定一樣的值並在 Cron Job
# 設定裡帶 Authorization: Bearer <值>（或讓 Vercel Cron 內建機制自動帶入，
# 視 Vercel 文件當時的作法而定）
# CRON_SECRET=

# 已申請：LINE Login channel「LunchBot 點餐」底下的 LIFF App「員工點餐頁」
# LIFF ID 不是敏感資訊（會直接嵌在前端網址/程式碼裡），可以放實際值在這裡
NEXT_PUBLIC_LINE_LIFF_ID=2010418986-djEPOUcf
